# Supabase — copie para .env e preencha os valores
# Obtenha em: https://app.supabase.com → seu projeto → Settings → API
VITE_SUPABASE_URL=https://ypkulvbllxgkjzhpzemf.supabase.co
VITE_SUPABASE_ANON_KEY=

# Versão do app (opcional, exibida nas Configurações)
VITE_APP_VERSION=0.1.1

# Upstash Redis — notificações push via Flask backend
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# URL base da API Flask do ReservaLab (opicional — vazio = mesmo domínio)
VITE_RESERVALAB_API_URL=

# VAPID — chave pública para Web Push (frontend se inscrever)
VITE_VAPID_PUBLIC_KEY=

# ── Variáveis do backend Flask (ReservaLab) ──
# Usadas no deploy Vercel do backend, não no frontend.
# A URL do SharePoint precisa ter ?download=1 para forçar download direto.
# SHAREPOINT_URL=https://animaeducacao-my.sharepoint.com/...?download=1
# INVENTARIO_URL=...
# SUPABASE_URL=...
# SUPABASE_SERVICE_KEY=...
